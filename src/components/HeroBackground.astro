---
// merricstrough.com — Hero background plane (per ADR-0002 §Hero composition).
// Switches on hero.backgroundMode: 'image' | 'canvas' | 'layered'.
import HeroCanvas from '@components/HeroCanvas.astro';
import type { Hero } from '@data/site-content';

interface Props {
  mode: Hero['backgroundMode'];
  image?: string | undefined;
  canvasPreset: NonNullable<Hero['canvasPreset']>;
}

const { mode, image, canvasPreset } = Astro.props;
const showImage = (mode === 'image' || mode === 'layered') && Boolean(image);
const showCanvas = mode === 'canvas' || mode === 'layered';
const canvasOpacity = mode === 'layered' ? 0.4 : 1;

// Strip extension to compose AVIF + WebP companion paths. Pages CMS uploads
// land in /public/hero/*.{jpg,png}; the optimize-images.mjs pipeline writes
// .avif + .webp siblings. If they're missing the <picture> degrades to JPEG.
const imageBase = image?.replace(/\.(jpg|jpeg|png|webp)$/i, '');
---

<div class="hero-bg" aria-hidden="true">
  {showImage && image && imageBase && (
    <picture>
      <source type="image/avif" srcset={`${imageBase}.avif`} />
      <source type="image/webp" srcset={`${imageBase}.webp`} />
      <img
        src={image}
        alt=""
        class="hero-bg__image"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
  )}
  {showCanvas && <HeroCanvas preset={canvasPreset} opacity={canvasOpacity} />}
  <div class="hero-bg__veil"></div>
</div>

<style>
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-bg__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Subtle scale so any motion behind feels framed by the image. */
    transform: scale(1.02);
    /* Apply a deep mask so type stays legible even on bright photos. */
    filter: brightness(0.55) saturate(1.1);
  }

  .hero-bg__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at 50% 100%,
        var(--color-accent-glow) 0%,
        transparent 55%
      ),
      linear-gradient(
        180deg,
        oklch(14% 0.015 285 / 0.4) 0%,
        oklch(14% 0.015 285 / 0.85) 70%,
        var(--color-canvas) 100%
      );
    pointer-events: none;
  }

  /* sRGB fallback for the veil */
  @supports not (color: oklch(0% 0 0)) {
    .hero-bg__veil {
      background:
        radial-gradient(
          ellipse at 50% 100%,
          rgba(139, 107, 255, 0.4) 0%,
          transparent 55%
        ),
        linear-gradient(180deg, rgba(26, 24, 32, 0.4) 0%, rgba(26, 24, 32, 0.85) 70%, #1a1820 100%);
    }
  }
</style>
