---
// merricstrough.com — v2 landing page.
// Composition per ADR-0002 §Hero composition system.
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Identity from '@components/Identity.astro';
import Projects from '@components/Projects.astro';
import FollowGrid from '@components/FollowGrid.astro';
import TopTracks from '@components/TopTracks.astro';
---

<BaseLayout
  title="Merric S. — building, gaming, making"
  description="Merric's corner of the internet — Minecraft, art, gaming, and what's next."
  includePersonSchema={true}
>
  <Hero />
  <main id="main-content">
    <Identity />
    <TopTracks />
    <Projects />
    <FollowGrid />
  </main>
</BaseLayout>
