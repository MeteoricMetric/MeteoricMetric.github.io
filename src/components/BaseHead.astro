---
// merricstrough.com — universal <head> component (per ADR-0003 + ADR-0002).
// Owns: charset, viewport, title/description, canonical, Open Graph,
// Twitter card, rel=me identity links, favicons, theme-color, fonts.
import { verifiedAccounts } from '@data/accounts';
import { parent } from '@data/family';
import FontLoader from '@components/FontLoader.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;

// Strip query + hash from the current URL so canonical points at the
// resource, not at a parameterized variant. Authors may pass `canonical`
// explicitly to override (e.g. for RSS or alternate-domain landings).
const currentUrl = new URL(Astro.url.toString());
currentUrl.search = '';
currentUrl.hash = '';
const canonicalHref = canonical ?? currentUrl.toString();

const ogImageHref = ogImage ?? '/og-default.png';
const siteName = 'merricstrough.com';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#1a1820" />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalHref} />

{/* Open Graph */}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:type" content="website" />
<meta property="og:image" content={ogImageHref} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="en_US" />

{/* Twitter card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageHref} />

{/* IndieWeb identity — outgoing rel=me to parent + each verified account. */}
<link rel="me" href={parent.url} />
{verifiedAccounts.map((account) => <link rel="me" href={account.url} />)}

{/*
  Modern browsers use the SVG favicon at any size. Web App Manifest
  enables Add-to-Home-Screen on mobile.
  TODO(phase-2): generate raster fallbacks (apple-touch-icon 180px,
  favicon.ico, icon-192/512 PNG) for Safari iOS / very-old-browser
  parity. Defer until after v2 ships.
*/}
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="manifest" href="/manifest.webmanifest" />

<FontLoader />
