---
// merricstrough.com — font loader (per ADR-0002 §Typography).
//
// Geist Sans + Geist Mono variable woff2 files ship in /public/fonts/
// (sourced from the `geist` npm package; the package's exports map blocks
// deep imports of the woff2 binaries from Vite, so we copy them into
// /public/ and reference them by URL — keeps the build independent of
// geist's internal layout). Italic variants included for editorial moments.
//
// Newsreader (serif accent) ships from Google Fonts in v1; self-hosting
// deferred per ADR-0002 §Open items.
---

{/* Preload the critical face only (Geist Sans variable upright) per ADR-0002 perf budget. */}
<link
  rel="preload"
  as="font"
  type="font/woff2"
  href="/fonts/Geist-Variable.woff2"
  crossorigin="anonymous"
/>

{/* Newsreader — Google Fonts in v1; self-host deferred. */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&display=swap"
/>

{/*
  Self-hosted Geist @font-face declarations. Emitted as a global style block
  so the rules apply document-wide (Astro scopes <style> to the component
  by default, which would defeat font registration).
*/}
<style is:global>
  @font-face {
    font-family: 'Geist';
    font-style: normal;
    font-weight: 100 900;
    font-display: swap;
    src: url('/fonts/Geist-Variable.woff2') format('woff2-variations');
  }

  @font-face {
    font-family: 'Geist';
    font-style: italic;
    font-weight: 100 900;
    font-display: swap;
    src: url('/fonts/Geist-Italic-Variable.woff2') format('woff2-variations');
  }

  @font-face {
    font-family: 'Geist Mono';
    font-style: normal;
    font-weight: 100 900;
    font-display: swap;
    src: url('/fonts/GeistMono-Variable.woff2') format('woff2-variations');
  }

  @font-face {
    font-family: 'Geist Mono';
    font-style: italic;
    font-weight: 100 900;
    font-display: swap;
    src: url('/fonts/GeistMono-Italic-Variable.woff2') format('woff2-variations');
  }
</style>
