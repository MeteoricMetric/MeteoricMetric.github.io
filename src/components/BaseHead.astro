---
// merricstrough.com — universal <head> component (per ADR-0003 + ADR-0002).
// Owns: charset, viewport, title/description, canonical, Open Graph,
// Twitter card, rel=me identity links, favicons, theme-color, fonts.
import { verifiedAccounts } from '@data/accounts';
import { parent } from '@data/family';
import FontLoader from '@components/FontLoader.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;

// Strip query + hash from the current URL so canonical points at the
// resource, not at a parameterized variant. Authors may pass `canonical`
// explicitly to override (e.g. for RSS or alternate-domain landings).
const currentUrl = new URL(Astro.url.toString());
currentUrl.search = '';
currentUrl.hash = '';
const canonicalHref = canonical ?? currentUrl.toString();

const ogImageHref = ogImage ?? '/og-default.png';
const siteName = 'merricstrough.com';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#1a1820" />

{/*
  Content Security Policy via meta http-equiv. GitHub Pages can't set
  HTTP headers, so meta is our only delivery vehicle. 'unsafe-inline'
  is required because Astro 6 ships scoped <style> + view-transition
  scripts inline; tighten via experimental.csp + nonces in Phase 2
  (the experimental.csp config flag is not yet recognized in Astro
  6.2.1; revisit when it lands stable).
  frame-ancestors / report-to / sandbox don't work in meta and are
  intentionally omitted.
*/}
<meta
  http-equiv="Content-Security-Policy"
  content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' https: data:; connect-src 'self' https://*.workers.dev; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
/>

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalHref} />

{/* Open Graph */}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:type" content="website" />
<meta property="og:image" content={ogImageHref} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="en_US" />

{/* Twitter card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageHref} />

{/* Preload the LCP image (avatar) in modern format. Browsers without
    AVIF support (~2% in 2026) ignore the unsupported type and fall
    through to the <picture> tag's WebP / JPEG sources at render time. */}
<link
  rel="preload"
  as="image"
  type="image/avif"
  href="/avatar.avif"
  fetchpriority="high"
/>

{/* IndieWeb identity — outgoing rel=me to parent + each verified account. */}
<link rel="me" href={parent.url} />
{verifiedAccounts.map((account) => <link rel="me" href={account.url} />)}

{/*
  Modern browsers prefer the SVG favicon and scale it to any size;
  raster fallbacks below cover Safari iOS Add-to-Home-Screen, Android
  home-screen, and very-old-browser parity. Generated by
  `npm run favicons` from public/favicon.svg via sharp.
*/}
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/manifest.webmanifest" />

<FontLoader />
